generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Participant {
  id        String        @id @default(cuid())
  nick      String
  createdAt DateTime      @default(now())
  spins     SpinHistory[]
}

model AccessKey {
  id          String        @id @default(cuid())
  code        String        @unique
  label       String?
  singleUse   Boolean       @default(true)
  active      Boolean       @default(true)
  expiresAt   DateTime?
  usedAt      DateTime?
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  spins       SpinHistory[]
}

model WheelItem {
  id          String        @id @default(cuid())
  name        String
  imageUrl    String
  rarity      String
  probability Decimal       @db.Decimal(9, 4)
  active      Boolean       @default(true)
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  spins       SpinHistory[]
}

model SpinHistory {
  id            String      @id @default(cuid())
  participantId String
  accessKeyId   String
  itemId        String
  participant   Participant @relation(fields: [participantId], references: [id])
  accessKey     AccessKey   @relation(fields: [accessKeyId], references: [id])
  item          WheelItem   @relation(fields: [itemId], references: [id])
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime    @default(now())

  @@index([createdAt])
  @@index([accessKeyId])
  @@index([itemId])
}

model GeneralSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
